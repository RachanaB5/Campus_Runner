# Database Configuration
DATABASE_URL=sqlite:///campuscanteen.db
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production-12345
JWT_ACCESS_TOKEN_EXPIRES=3600

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Email — use either pair below (Gmail: use an App Password, not your normal password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-sender@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_DEFAULT_SENDER=your-sender@gmail.com
# Optional: set true to send order/notification mail in a thread (default is synchronous — more reliable with Flask debug/reloader)
# MAIL_ASYNC_SEND=false

# Legacy aliases (still read by app.py if MAIL_* are empty)
# EMAIL_ADDRESS=your-sender@gmail.com
# EMAIL_PASSWORD=your-16-char-app-password

# Admin Settings
ADMIN_EMAIL=admin@campuscanteen.com
ADMIN_PASSWORD=admin123
# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-email

# Frontend URL
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
