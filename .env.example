# Database Configuration
DATABASE_URL=sqlite:///campusrunner.db

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production

# Email Configuration (Optional - for order confirmations)
# Using Gmail: https://support.google.com/accounts/answer/185833
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_DEFAULT_SENDER=noreply@campusrunner.com

# Alternative Email Services:
# For SendGrid: MAIL_SERVER=smtp.sendgrid.net, MAIL_PORT=587, MAIL_USERNAME=apikey
# For AWS SES: MAIL_SERVER=email-smtp.region.amazonaws.com, MAIL_PORT=587
# For Outlook: MAIL_SERVER=smtp-mail.outlook.com, MAIL_PORT=587

# Application Settings
FLASK_ENV=development
DEBUG=True
